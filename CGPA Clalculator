export const GRADES = [
  { label: 'O  — 10', value: 10, symbol: 'O'  },
  { label: 'A+ — 9',  value: 9,  symbol: 'A+' },
  { label: 'A  — 8',  value: 8,  symbol: 'A'  },
  { label: 'B+ — 7',  value: 7,  symbol: 'B+' },
  { label: 'B  — 6',  value: 6,  symbol: 'B'  },
  { label: 'C  — 5',  value: 5,  symbol: 'C'  },
  { label: 'D  — 4',  value: 4,  symbol: 'D'  },
  { label: 'F  — 0',  value: 0,  symbol: 'F'  },
];

export const GRADE_COLORS = {
  10: '#34D399', 9: '#34D399', 8: '#A78BFA',
  7: '#60A5FA',  6: '#F59E0B', 5: '#FB923C',
  4: '#F87171',  0: '#EF4444',
};

export function getGradeSymbol(gp) {
  const map = { 10:'O', 9:'A+', 8:'A', 7:'B+', 6:'B', 5:'C', 4:'D', 0:'F' };
  return map[gp] ?? 'F';
}

export function getGradeRemarks(sgpa) {
  if (sgpa >= 9) return { text: 'Outstanding 🏆', color: '#34D399' };
  if (sgpa >= 8) return { text: 'Excellent ⭐',   color: '#34D399' };
  if (sgpa >= 7) return { text: 'Very Good 👍',   color: '#A78BFA' };
  if (sgpa >= 6) return { text: 'Good 😊',        color: '#60A5FA' };
  if (sgpa >= 5) return { text: 'Average ⚠️',     color: '#F59E0B' };
  return           { text: 'Needs Work ❌',        color: '#F87171' };
}

