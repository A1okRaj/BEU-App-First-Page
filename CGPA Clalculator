import React, { useRef, useEffect } from 'react';
import { View, Text, StyleSheet, Animated } from 'react-native';
import Svg, { Circle } from 'react-native-svg';
import { LinearGradient } from 'expo-linear-gradient';
import { C, GRADE_COLORS } from '../theme/colors';
import { getGradeSymbol, getGradeRemarks } from '../utils/grades';

const SIZE = 140;
const R    = 60;
const CIRC = 2 * Math.PI * R;

// Animated SVG circle wrapper
import Animated as AN from 'react-native';
const AnimatedCircle = Animated.createAnimatedComponent(Circle);

export default function ResultRing({ sgpa, calculated, subjects, totalCredits, activeSem }) {
  const dashAnim   = useRef(new Animated.Value(CIRC)).current;
  const colorValue = useRef(new Animated.Value(0)).current;

  useEffect(() => {
    const target = calculated ? CIRC - CIRC * (sgpa / 10) : CIRC * 0.7;
    Animated.timing(dashAnim, { toValue: target, duration: 700, useNativeDriver: false }).start();
  }, [sgpa, calculated]);

  const ringColor = calculated
    ? (GRADE_COLORS[Math.round(sgpa)] || C.p)
    : 'rgba(167,139,250,0.3)';

  const remarks = getGradeRemarks(sgpa);

  const STATS = [
    { n: subjects.length,  l: 'Subjects', c: C.p    },
    { n: totalCredits,     l: 'Credits',  c: C.teal  },
    { n: `Sem ${activeSem}`,l: 'Current', c: C.gold  },
  ];

  return (
    <LinearGradient
      colors={['rgba(124,58,237,0.2)', 'rgba(45,212,191,0.1)']}
      style={s.card}
    >
      <View style={s.topBorder} />

      {/* SVG RING */}
      <View style={s.ringWrap}>
        <Svg width={SIZE} height={SIZE}>
          {/* Track */}
          <Circle cx={SIZE/2} cy={SIZE/2} r={R}
            stroke="rgba(255,255,255,0.07)" strokeWidth={10} fill="none" />
          {/* Fill — static snapshot (Animated SVG in RN needs workaround) */}
          <Circle cx={SIZE/2} cy={SIZE/2} r={R}
            stroke={ringColor} strokeWidth={10} fill="none"
            strokeDasharray={CIRC}
            strokeDashoffset={calculated ? CIRC - CIRC * (sgpa / 10) : CIRC * 0.7}
            strokeLinecap="round"
            rotation={-90} origin={`${SIZE/2},${SIZE/2}`}
          />
        </Svg>
        {/* Center text */}
        <View style={s.center}>
          <Text style={[s.sgpaNum, { color: calculated ? ringColor : C.t3 }]}>
            {calculated ? sgpa.toFixed(2) : '—'}
          </Text>
          <Text style={s.sgpaLbl}>SGPA</Text>
        </View>
      </View>

      {/* GRADE + REMARK */}
      {calculated ? (
        <>
          <Text style={[s.grade, { color: remarks.color }]}>
            {getGradeSymbol(Math.round(sgpa))} Grade
          </Text>
          <Text style={[s.remark, { color: remarks.color }]}>{remarks.text}</Text>
        </>
      ) : (
        <Text style={s.hint}>Grades bharke Calculate karo 👇</Text>
      )}

      {/* STAT BOXES */}
      <View style={s.statsRow}>
        {STATS.map((st, i) => (
          <View key={i} style={s.statBox}>
            <Text style={[s.statN, { color: st.c }]}>{st.n}</Text>
            <Text style={s.statL}>{st.l}</Text>
          </View>
        ))}
      </View>
    </LinearGradient>
  );
}

const s = StyleSheet.create({
  card: {
    borderRadius:24, borderWidth:1,
    borderColor:'rgba(167,139,250,0.2)',
    padding:22, marginBottom:14,
    alignItems:'center', overflow:'hidden',
  },
  topBorder: {
    position:'absolute', top:0, left:0, right:0, height:1,
    backgroundColor:'rgba(167,139,250,0.6)',
  },
  ringWrap: { width:SIZE, height:SIZE, marginBottom:16 },
  center: {
    ...StyleSheet.absoluteFillObject,
    alignItems:'center', justifyContent:'center',
  },
  sgpaNum:  { fontSize:34, fontWeight:'900', lineHeight:38 },
  sgpaLbl:  { fontSize:10, color:C.t3, letterSpacing:1, textTransform:'uppercase', marginTop:2 },
  grade:    { fontSize:22, fontWeight:'800', marginBottom:4 },
  remark:   { fontSize:12, marginBottom:4 },
  hint:     { fontSize:13, color:C.t3, marginBottom:4 },
  statsRow: { flexDirection:'row', gap:10, marginTop:14, width:'100%' },
  statBox: {
    flex:1, backgroundColor:'rgba(0,0,0,0.25)',
    borderRadius:12, padding:10, alignItems:'center',
    borderWidth:1, borderColor:'rgba(255,255,255,0.06)',
  },
  statN: { fontSize:18, fontWeight:'700' },
  statL: { fontSize:9,  color:C.t3, marginTop:2, textTransform:'uppercase', letterSpacing:0.5 },
});




