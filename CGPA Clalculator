import React from 'react';
import { View, Text, StyleSheet, TouchableOpacity } from 'react-native';
import { Picker } from '@react-native-picker/picker';
import { C, GRADES, GRADE_COLORS } from '../theme/colors';

export default function SubjectInputCard({ subjects, onGradeChange, onCreditChange, onDelete }) {
  return (
    <View style={s.card}>
      {subjects.map((sub, idx) => {
        const gc = GRADE_COLORS[sub.grade] || C.p;
        return (
          <View key={sub.id} style={[s.row, idx < subjects.length - 1 && s.rowBorder]}>
            {/* LEFT: Name + credit */}
            <View style={s.left}>
              <Text style={s.name} numberOfLines={1}>{sub.name}</Text>
              {/* Credit buttons */}
              <View style={s.creditRow}>
                <TouchableOpacity
                  style={s.cb}
                  onPress={() => onCreditChange(sub.id, -1)}
                  activeOpacity={0.75}
                >
                  <Text style={s.cbText}>−</Text>
                </TouchableOpacity>
                <Text style={s.creditVal}>{sub.credit}</Text>
                <TouchableOpacity
                  style={s.cb}
                  onPress={() => onCreditChange(sub.id, +1)}
                  activeOpacity={0.75}
                >
                  <Text style={s.cbText}>+</Text>
                </TouchableOpacity>
                <Text style={s.creditLbl}>cr</Text>
              </View>
            </View>

            {/* RIGHT: Grade Picker + Delete */}
            <View style={s.right}>
              <View style={[s.pickerWrap, { borderColor: gc + '50' }]}>
                <Picker
                  selectedValue={sub.grade}
                  onValueChange={val => onGradeChange(sub.id, val)}
                  style={[s.picker, { color: gc }]}
                  dropdownIconColor={gc}
                  mode="dropdown"
                >
                  {GRADES.map(g => (
                    <Picker.Item
                      key={g.value}
                      label={g.label}
                      value={g.value}
                      color={C.t1}
                    />
                  ))}
                </Picker>
              </View>
              <TouchableOpacity
                style={s.del}
                onPress={() => onDelete(sub.id)}
                activeOpacity={0.75}
              >
                <Text style={s.delText}>🗑️</Text>
              </TouchableOpacity>
            </View>
          </View>
        );
      })}
    </View>
  );
}

const s = StyleSheet.create({
