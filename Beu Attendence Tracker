import React, { useRef, useEffect } from 'react';
import { View, Text, StyleSheet, Animated } from 'react-native';
import { LinearGradient } from 'expo-linear-gradient';
import { C } from '../theme/colors';
import { getStatus } from '../utils/attendance';

export default function OverallCard({ totalPresent, totalClasses, subjects }) {
  const overallPct    = totalClasses > 0 ? Math.round((totalPresent / totalClasses) * 100) : 0;
  const overallStatus = getStatus(overallPct);
  const barAnim       = useRef(new Animated.Value(0)).current;

  useEffect(() => {
    Animated.timing(barAnim, {
      toValue: overallPct / 100, duration: 700,
      useNativeDriver: false,
    }).start();
  }, [overallPct]);

  const barWidth = barAnim.interpolate({ inputRange: [0, 1], outputRange: ['0%', '100%'] });

  const STATS = [
    { n: totalPresent,                    l: 'Present',  c: C.green },
    { n: totalClasses - totalPresent,     l: 'Absent',   c: C.red   },
    { n: subjects.length,                 l: 'Subjects', c: C.p     },
  ];

  return (
    <LinearGradient colors={['rgba(124,58,237,0.2)','rgba(255,140,66,0.12)']} style={s.card}>
      {/* Top border glow */}
      <View style={s.topBorder} />

      {/* Percent + Status */}
      <View style={s.topRow}>
        <View>
          <Text style={[s.pct, { color: overallStatus.color }]}>{overallPct}%</Text>
          <Text style={s.label}>Overall Attendance</Text>
        </View>
        <View style={s.right}>
          <View style={[s.statusPill, { backgroundColor: overallStatus.color + '18', borderColor: overallStatus.color + '35' }]}>
            <Text style={[s.statusText, { color: overallStatus.color }]}>{overallStatus.text}</Text>
          </View>
          <Text style={s.classes}>{totalPresent}/{totalClasses} Classes</Text>
        </View>
      </View>

      {/* Progress Bar */}
      <View style={s.barTrack}>
        <Animated.View style={[s.barFill, { width: barWidth, backgroundColor: overallStatus.color }]} />
      </View>
      <View style={s.barLabels}>
        <Text style={s.barLbl}>0%</Text>
        <Text style={[s.barLbl, { color: C.gold }]}>75% Min</Text>
        <Text style={s.barLbl}>100%</Text>
      </View>

      {/* Stat Boxes */}
      <View style={s.statRow}>
        {STATS.map((st, i) => (
          <View key={i} style={s.statBox}>
            <Text style={[s.statN, { color: st.c }]}>{st.n}</Text>
            <Text style={s.statL}>{st.l}</Text>
          </View>
        ))}
      </View>
    </LinearGradient>
  );
}

const s = StyleSheet.create({
  card: {
    borderRadius: 22, borderWidth: 1,
    borderColor: 'rgba(167,139,250,0.2)',
    padding: 20, marginBottom: 14, overflow: 'hidden',
  },
  topBorder: {
