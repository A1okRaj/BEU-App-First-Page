// ================================================================
// FILE: src/utils/attendance.js
// ================================================================
export function getStatus(pct) {
  if (pct >= 90) return { text: 'Excellent 🌟', color: '#34D399' };
  if (pct >= 75) return { text: 'Safe ✓',       color: '#34D399' };
  if (pct >= 65) return { text: 'Warning ⚠',    color: '#F59E0B' };
  return           { text: 'Danger ✗',          color: '#F87171' };
}

export function getBunkInfo(present, total, minPct = 75) {
  const pct      = total > 0 ? (present / total) * 100 : 0;
  const needed   = Math.ceil((minPct * total - 100 * present) / (100 - minPct));
  const canBunk  = Math.floor((100 * present - minPct * total) / minPct);
  return { canBunk: Math.max(0, canBunk), needed: Math.max(0, needed), pct };
}

