    backgroundColor: 'rgba(167,139,250,0.5)',
  },
  topRow:     { flexDirection: 'row', justifyContent: 'space-between', alignItems: 'flex-start', marginBottom: 16 },
  pct:        { fontSize: 52, fontWeight: '800', lineHeight: 56 },
  label:      { fontSize: 11, color: C.t2, marginTop: 4 },
  right:      { alignItems: 'flex-end', gap: 8 },
  statusPill: { borderWidth: 1, borderRadius: 20, paddingHorizontal: 14, paddingVertical: 5 },
