import React from 'react';
import { View, Text, StyleSheet } from 'react-native';
import { C } from '../theme/colors';
import { COMPANIES, MY_APPLICATIONS } from '../data/placementData';

export default function StatsRow() {
  const open   = COMPANIES.filter(c => c.status === 'Open').length;
  const applied = MY_APPLICATIONS.length;
  const short  = MY_APPLICATIONS.filter(a => a.status === 'Shortlisted').length;
  const STATS  = [
    { n:`${COMPANIES.length}`, l:'Companies', c:C.green },
    { n:`${open}`,             l:'Open',      c:C.gold  },
    { n:`${applied}`,          l:'Applied',   c:C.p     },
    { n:`${short}`,            l:'Shortlisted',c:C.teal },
  ];
  return (
    <View style={s.row}>
      {STATS.map((st, i) => (
        <View key={i} style={s.box}>
          <Text style={[s.n, { color:st.c }]}>{st.n}</Text>
          <Text style={s.l}>{st.l}</Text>
        </View>
      ))}
    </View>
  );
}
const s = StyleSheet.create({
  row: { flexDirection:'row', gap:8, marginBottom:14 },
  box: { flex:1, backgroundColor:C.card, borderRadius:14, borderWidth:1, borderColor:C.border, padding:11, alignItems:'center' },
  n:   { fontSize:20, fontWeight:'800' },
  l:   { fontSize:8, color:C.t3, marginTop:2, textTransform:'uppercase', letterSpacing:0.3 },
});




