import React, { useRef, useEffect } from 'react';
import { View, Text, StyleSheet, TouchableOpacity, Animated } from 'react-native';
import { LinearGradient } from 'expo-linear-gradient';
import { C } from '../theme/colors';
import { COMPANIES } from '../data/placementData';

export default function LiveBanner({ onPress }) {
  const pulse = useRef(new Animated.Value(1)).current;
  const live  = COMPANIES.find(c => c.status === 'Open' && c.type === 'Product') || COMPANIES[0];

  useEffect(() => {
    Animated.loop(
      Animated.sequence([
        Animated.timing(pulse, { toValue:0.2, duration:700, useNativeDriver:true }),
        Animated.timing(pulse, { toValue:1,   duration:700, useNativeDriver:true }),
      ])
    ).start();
  }, []);

  return (
    <TouchableOpacity onPress={() => onPress(live)} activeOpacity={0.85} style={{ marginBottom:14 }}>
      <LinearGradient colors={['rgba(245,158,11,0.18)','rgba(255,140,66,0.1)']} style={s.card}>
        <View style={s.topBorder} />
        <View style={s.topRow}>
          <View style={s.livePill}>
            <Animated.View style={[s.liveDot, { opacity:pulse }]} />
            <Text style={s.liveText}>LIVE</Text>
          </View>
          <Text style={s.deadline}>Closes {live.deadline}</Text>
        </View>
        <Text style={s.company}>{live.name}</Text>
        <Text style={s.role}>{live.role} · {live.type}</Text>
        <View style={s.chipsRow}>