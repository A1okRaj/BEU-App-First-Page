import React from 'react';
import { ScrollView, TouchableOpacity, Text, StyleSheet } from 'react-native';
import { C } from '../theme/colors';

export default function FilterRow({ items, active, onSelect, activeColor = C.green }) {
  return (
    <ScrollView horizontal showsHorizontalScrollIndicator={false}
      contentContainerStyle={s.row} style={s.scroll}>
      {items.map(item => {
        const on = active === item;
        return (
          <TouchableOpacity key={item}
            style={[s.pill, on && { backgroundColor:activeColor+'22', borderColor:activeColor+'55' }]}
            onPress={() => onSelect(item)} activeOpacity={0.75}>
            <Text style={[s.label, on && { color:activeColor }]}>{item}</Text>
          </TouchableOpacity>
        );
      })}
    </ScrollView>
  );
}
const s = StyleSheet.create({
  scroll: { marginBottom:10 },
  row:    { flexDirection:'row', gap:7, paddingBottom:4 },
