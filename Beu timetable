import React from 'react';
import { View, Text, StyleSheet, TouchableOpacity } from 'react-native';
import { C } from '../theme/colors';

const TYPE_STYLES = {
  Theory:    { bg:'rgba(167,139,250,0.12)', color:'#A78BFA' },
  Practical: { bg:'rgba(45,212,191,0.12)',  color:'#2DD4BF'  },
  Free:      { bg:'rgba(139,92,246,0.12)',  color:'#8B5CF6'  },
  Tutorial:  { bg:'rgba(255,140,66,0.12)',  color:'#FF8C42'  },
  Project:   { bg:'rgba(255,140,66,0.12)',  color:'#FF8C42'  },
};

function BreakCard({ period }) {
  return (
    <View style={s.breakCard}>
      <Text style={s.breakIco}>{period.name === 'LUNCH' ? '🍽️' : '☕'}</Text>
      <Text style={s.breakTitle}>{period.name}</Text>
      <Text style={s.breakDur}>{period.start} – {period.end} · {period.duration}</Text>
    </View>
  );
}

function PeriodCard({ period, isNow }) {
  const ts = TYPE_STYLES[period.type] || TYPE_STYLES.Theory;
  return (
    <TouchableOpacity style={[s.period, isNow && s.periodNow]} activeOpacity={0.8}>
      <View style={[s.leftBar, { backgroundColor: period.color }]} />

      {/* TIME COL */}
      <View style={s.timeCol}>
        <Text style={s.timeStart}>{period.start}</Text>
        <View style={s.timeLine} />
        <Text style={s.timeEnd}>{period.end}</Text>
      </View>

      {/* BODY */}
      <View style={s.body}>
        <View style={s.bodyTop}>
          <View style={s.bodyLeft}>
            <Text style={s.subjectName} numberOfLines={1}>{period.name}</Text>
            {!!period.code && <Text style={s.subjectCode}>{period.code}</Text>}
          </View>
          <View style={s.bodyRight}>
            <View style={s.roomBadge}>
              <Text style={s.roomText}>{period.room}</Text>
            </View>
            <View style={[s.typeBadge, { backgroundColor:ts.bg }]}>
              <Text style={[s.typeText, { color:ts.color }]}>{period.type}</Text>
            </View>
          </View>
        </View>

        {!!period.teacher && (
          <View style={s.teacherRow}>
            <View style={[s.teacherAv, { backgroundColor:period.color+'25' }]}>
              <Text style={[s.teacherAvText, { color:period.color }]}>
                {period.teacher.replace('Dr. ','').replace('Prof. ','')[0]}
              </Text>
            </View>
            <Text style={s.teacherName}>{period.teacher}</Text>
            {isNow && (
              <View style={s.nowBadge}>
                <Text style={s.nowBadgeText}>● NOW</Text>
              </View>
            )}
          </View>
        )}
      </View>
    </TouchableOpacity>
  );
}

export default function PeriodList({ periods, isNowFn }) {
  if (!periods || periods.length === 0) {
    return (
      <View style={s.empty}>
        <Text style={s.emptyIco}>📅</Text>
        <Text style={s.emptyText}>No classes today!</Text>
        <Text style={s.emptySub}>Enjoy your day off 🎉</Text>
      </View>
    );
  }

  return (
    <View style={s.list}>
      {periods.map((p, i) =>
        p.type === 'break'
          ? <BreakCard key={p.id || i} period={p} />
          : <PeriodCard key={p.id || i} period={p} isNow={isNowFn(p)} />
      )}
    </View>
  );
}

