import React from 'react';
import { ScrollView, TouchableOpacity, Text, View, StyleSheet } from 'react-native';
import { C, DAYS_SHORT } from '../theme/colors';

const TODAY_IDX = Math.min(new Date().getDay() === 0 ? 0 : new Date().getDay() - 1, 5);

export default function DayTabs({ active, onChange }) {
  return (
    <ScrollView
      horizontal showsHorizontalScrollIndicator={false}
      contentContainerStyle={s.row} style={s.scroll}
    >
      {DAYS_SHORT.map((d, i) => {
        const isOn    = active === i;
        const isToday = i === TODAY_IDX;
        return (
          <TouchableOpacity
            key={i}
            style={[s.tab, isOn && s.tabOn]}
            onPress={() => onChange(i)}
            activeOpacity={0.75}
          >
            <Text style={[s.dayLbl, isOn && s.dayLblOn]}>{d}</Text>
            <Text style={[s.dateLbl, isOn && { color:C.teal }]}>
              {isToday ? 'Today' : `Apr ${20+i}`}
            </Text>
          </TouchableOpacity>
        );
      })}
    </ScrollView>
  );
}

const s = StyleSheet.create({
  scroll: { marginBottom:14 },
  row:    { flexDirection:'row', gap:6, paddingBottom:4 },
  tab: {
    borderRadius:14, paddingHorizontal:14, paddingVertical:10,
    backgroundColor:C.card2, borderWidth:1, borderColor:C.border2,
    alignItems:'center', minWidth:60,
  },
  tabOn:   { backgroundColor:'rgba(45,212,191,0.14)', borderColor:'rgba(45,212,191,0.35)' },
  dayLbl:  { fontSize:11, fontWeight:'700', color:C.t2 },
  dayLblOn:{ color:C.teal },
  dateLbl: { fontSize:8, color:C.t3, marginTop:2 },
});




