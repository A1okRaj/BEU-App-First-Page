import React, { useRef, useEffect } from 'react';
import { View, Text, StyleSheet, Animated } from 'react-native';
import { C, gradeColor } from '../theme/colors';
import { RESULTS } from '../data/resultsData';

function TrendBar({ result, idx }) {
  const anim = useRef(new Animated.Value(0)).current;
  const pct  = result.sgpa ? result.sgpa / 10 : 0.05;
  const gc   = result.sgpa ? gradeColor(Math.round(result.sgpa)) : 'transparent';

  useEffect(() => {
    Animated.timing(anim, {
      toValue: pct, duration: 700, delay: idx * 80, useNativeDriver: false,
    }).start();
  }, []);

  const height = anim.interpolate({ inputRange:[0,1], outputRange:['0%','100%'] });

  return (
    <View style={s.col}>
      {result.sgpa && <Text style={[s.tip, { color:gc }]}>{result.sgpa}</Text>}
      <View style={s.barWrap}>
        <Animated.View style={[
          s.bar,
          { height, backgroundColor: result.sgpa ? gc : 'transparent',
            borderWidth: result.sgpa ? 0 : 1,
            borderColor:'rgba(255,255,255,0.15)',
            borderStyle:'dashed' },
        ]} />
      </View>
      <Text style={s.lbl}>S{idx+1}</Text>
    </View>
  );
}

export default function CgpaTrendCard({ cgpa }) {
  return (
    <View style={s.card}>
      <Text style={s.heading}>📈 CGPA Trend</Text>
      <View style={s.chart}>
        {RESULTS.map((r, i) => <TrendBar key={i} result={r} idx={i} />)}
      </View>
      <View style={s.divider} />
      <View style={s.footer}>
        <Text style={s.footerItem}>Best: <Text style={{ color:C.green, fontWeight:'700' }}>8.1 (Sem 2)</Text></Text>
        <Text style={s.footerItem}>CGPA: <Text style={{ color:C.gold, fontWeight:'700' }}>{cgpa}</Text></Text>
        <Text style={s.footerItem}>Trend: <Text style={{ color:C.green, fontWeight:'700' }}>↗ Rising</Text></Text>
      </View>
    </View>
  );
}

const s = StyleSheet.create({
