import React from 'react';
import { View, Text, StyleSheet, TouchableOpacity } from 'react-native';
import { LinearGradient } from 'expo-linear-gradient';
import { C, gradeColor, gpSymbol, getRemarks } from '../theme/colors';

const COL_HEADERS = ['Subject', 'Cr', 'GP', 'Marks'];

export default function SemResultCard({ result, onSubjectPress }) {
  const rem = result.sgpa ? getRemarks(result.sgpa) : null;

  return (
    <View style={s.card}>
      {/* SEM HEADER */}
      <LinearGradient
        colors={['rgba(52,211,153,0.1)','transparent']}
        style={s.header}
        start={{x:0,y:0}} end={{x:1,y:0}}
      >
        <View>
          <Text style={s.semTitle}>{result.sem}</Text>
          <Text style={s.semDate}>{result.date}</Text>
          {rem && <Text style={[s.remarks, { color:rem.c }]}>{rem.t}</Text>}
        </View>
        <View style={s.sgpaWrap}>
          {result.sgpa ? (
            <>
              <Text style={[s.sgpaNum, { color:gradeColor(Math.round(result.sgpa)) }]}>
                {result.sgpa}
              </Text>
              <Text style={s.sgpaLbl}>SGPA</Text>
              <Text style={s.rankText}>Rank #{result.rank}/{result.total}</Text>
            </>
          ) : (
            <>
              <Text style={[s.sgpaNum, { color:C.t3, fontSize:18 }]}>—</Text>
              <Text style={s.sgpaLbl}>Awaited</Text>
            </>
          )}
        </View>
      </LinearGradient>

      {/* TABLE HEADER */}
      <View style={[s.tableRow, s.tableHead]}>
        {COL_HEADERS.map((h, i) => (
          <Text key={i} style={[s.th, i===0 && s.wide]}>{h}</Text>
        ))}
      </View>

      {/* SUBJECT ROWS */}
      {result.subjects.map((sub, i) => {
        const gc = sub.gp ? gradeColor(sub.gp) : C.t3;
        return (
          <TouchableOpacity
            key={i}
            style={[s.tableRow, i < result.subjects.length-1 && s.rowBorder]}
            onPress={() => onSubjectPress(sub)}
            activeOpacity={0.75}
          >
            <View style={s.wide}>
              <Text style={s.subName} numberOfLines={1}>{sub.name}</Text>
              <Text style={s.subCode}>{sub.code}</Text>
            </View>
            <Text style={[s.td, { color:C.teal }]}>{sub.credits}</Text>
            <Text style={[s.td, { color:gc, fontW