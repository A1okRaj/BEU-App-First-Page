  { n:'8th',  l:'Best Rank',   c:C.gold  },
  { n:'12th', l:'Avg Rank',    c:C.or    },
  { n:'60',   l:'Class Size',  c:C.teal  },
];

export default function RankCard({ rank = 8, total = 60 }) {
  const barAnim = useRef(new Animated.Value(0)).current;
  const pct     = ((total - rank) / total) * 100;

  useEffect(() => {
    Animated.timing(barAnim, {
      toValue: pct / 100, duration: 800, useNativeDriver: false,
    }).start();
  }, []);

  const barWidth = barAnim.interpolate({ inputRange:[0,1], outputRange:['0%','100%'] });

  return (
    <LinearGradient
      colors={['rgba(245,158,11,0.15)','rgba(255,140,66,0.08)']}
      style={s.card}
    >
      <View style={s.topBorder} />
      <View style={s.top}>
        <View>
          <Text style={s.eyebrow}>CURRENT CLASS RANK</Text>
          <Text style={s.rankNum}>#{rank}</Text>
          <Text style={s.rankOut}>out of {total} students</Text>
        </View>
        <Text style={s.trophy}>🏆</Text>
      </View>
      <View style={s.barTrack}>
        <Animated.View style={[s.barFill, { width: barWidth }]} />
      </View>
      <Text style={s.barLbl}>Top {Math.round((rank/total)*100)}% of class</Text>
      <View style={s.statsRow}>
        {RANK_STATS.map((st, i) => (
          <View key={i} style={s.statBox}>
            <Text style={[s.statN, { color:st.c }]}>{st.n}</Text>
            <Text style={s.statL}>{st.l}</Text>
          </View>
        ))}
      </View>
    </LinearGradient>
  );
}

