  bg2:     '#0F0C1A',
  card:    '#16132A',
  card2:   '#1E1A35',
  card3:   '#252040',
  border:  'rgba(255,255,255,0.07)',
  border2: 'rgba(255,255,255,0.13)',
  t1:      '#F5F0FF',
  t2:      'rgba(245,240,255,0.6)',
  t3:      'rgba(245,240,255,0.25)',
  p:       '#A78BFA',
  p2:      '#7C3AED',
  or:      '#FF8C42',
  teal:    '#2DD4BF',
  pink:    '#F472B6',
  gold:    '#F59E0B',
  green:   '#34D399',
  red:     '#F87171',
  blue:    '#60A5FA',
};

export const GRADE_COLOR = {
  10:'#34D399', 9:'#34D399', 8:'#A78BFA',
  7:'#60A5FA',  6:'#F59E0B', 5:'#FB923C',
  4:'#F87171',  0:'#EF4444',
};

export const GP_SYMBOL = {
  10:'O', 9:'A+', 8:'A', 7:'B+',
  6:'B',  5:'C',  4:'D', 0:'F',
};

export function gradeColor(gp) { return GRADE_COLOR[gp] || C.p; }
export function gpSymbol(gp)   { return GP_SYMBOL[gp]   || '—'; }
export function getRemarks(sgpa) {
  if (sgpa >= 9) return { t:'Outstanding 🏆', c:C.green };
  if (sgpa >= 8) return { t:'Excellent ⭐',   c:C.green };
  if (sgpa >= 7) return { t:'Very Good 👍',   c:C.p     };
  if (sgpa >= 6) return { t:'Good 😊',        c:C.blue  };
  if (sgpa >= 5) return { t:'Pass ⚠️',        c:C.gold  };
  return           { t:'Fail ❌',             c:C.red   };
}




