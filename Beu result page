import React from 'react';
import { ScrollView, TouchableOpacity, Text, View, StyleSheet } from 'react-native';
import { C } from '../theme/colors';
import { RESULTS } from '../data/resultsData';

export default function SemTabs({ active, onChange }) {
  return (
    <ScrollView
      horizontal showsHorizontalScrollIndicator={false}
      contentContainerStyle={s.row} style={s.scroll}
    >
      {RESULTS.map((r, i) => {
        const isOn = active === i;
        return (
          <TouchableOpacity
            key={i}
            style={[s.tab, isOn && s.tabOn]}
            onPress={() => onChange(i)}
            activeOpacity={0.75}
          >
            <Text style={[s.label, isOn && s.labelOn]}>Sem {i+1}</Text>
            {!r.sgpa && <View style={s.dot} />}
          </TouchableOpacity>
        );
      })}
    </ScrollView>
  );
}

