export function getHolidaysForDate(dateStr) {
  return HOLIDAYS.filter(h => {
    const hDate = new Date(h.date);
    const check = new Date(dateStr);
    if (h.days > 1) {
      const end = new Date(hDate);
      end.setDate(end.getDate() + h.days - 1);
      return check >= hDate && check <= end;
    }
    return h.date === dateStr;
  });
}

export function getDayType(year, month, day) {
  const dateStr = `${year}-${String(month+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
  const dow     = new Date(dateStr).getDay();
  const holidays = getHolidaysForDate(dateStr);
  if (holidays.length > 0) return holidays[0].type;
  if (dow === 0) return 'sunday';
  if (dow === 6) return 'saturday';
  return null;
}

export function getUpcomingHolidays(n = 5) {
  const today = new Date();
  return HOLIDAYS
    .filter(h => new Date(h.date) >= today)
    .sort((a, b) => new Date(a.date) - new Date(b.date))
    .slice(0, n);
}

export function daysUntil(dateStr) {
  const diff = new Date(dateStr) - new Date();
  return Math.max(0, Math.ceil(diff / 86400000));
}




