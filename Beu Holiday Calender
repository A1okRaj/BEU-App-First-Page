const DAY_HEAD_COLORS = ['#F87171', C.t3, C.t3, C.t3, C.t3, C.t3, '#A78BFA'];

export default function CalendarGrid({ year, month, onDayPress }) {
  const daysInMonth  = new Date(year, month + 1, 0).getDate();
  const firstDay     = new Date(year, month, 1).getDay();
  const today        = new Date();

  const cells = [];
  for (let i = 0; i < firstDay; i++) cells.push(null);
  for (let d = 1; d <= daysInMonth; d++) cells.push(d);

  // pad to full rows
  while (cells.length % 7 !== 0) cells.push(null);

  const isToday = (d) =>
    d && year === today.getFullYear() && month === today.getMonth() && d === today.getDate();

  return (
    <View style={s.card}>
      {/* HEADERS */}
      <View style={s.headRow}>
        {DAY_HEADS.map((dh, i) => (
          <View key={i} style={s.headCell}>
            <Text style={[s.headText, { color: DAY_HEAD_COLORS[i] }]}>{dh}</Text>
          </View>
        ))}
      </View>
      {/* GRID */}
      <View style={s.grid}>
        {cells.map((day, i) => {
          if (!day) return <View key={`e-${i}`} style={s.cell} />;
          const dateStr  = `${year}-${String(month+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
          const dayType  = getDayType(year, month, day);
          const isT      = isToday(day);
          const tc       = dayType && TYPE_COLORS[dayType];
          const tbg      = dayType && TYPE_BG[dayType];
          const tbr      = dayType && TYPE_BORDER[dayType];
          const holidays = getHolidaysForDate(dateStr);

          return (
            <TouchableOpacity
              key={day}
              style={[
                s.cell,
                tbg  && { backgroundColor: tbg },
                tbr  && { borderColor: tbr, borderWidth: 1 },
                isT  && s.cellToday,
              ]}
              onPress={() => day && onDayPress(day, dateStr, holidays)}
              activeOpacity={0.7}
            >
              <Text style={[
                s.dayNum,
                tc  && { color: tc, fontWeight:'800' },
                isT && { color: C.p, fontWeight:'800' },
              ]}>{day}</Text>
              {holidays.length > 0 && (
                <View style={[s.dot, { backgroundColor: holidays[0].color }]} />
              )}
            </TouchableOpacity>
          );
        })}
      </View>
    </View>
  );
}

